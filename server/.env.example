DATABASE_URL="file:./prisma/dev.db"
# REQUIRED in production: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
PORT=3001
NODE_ENV=development
PUBLIC_BASE_URL="http://localhost:3001"
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
ADMIN_EMAIL="admin@goodveen.com"
# REQUIRED: change before first deploy
ADMIN_PASSWORD=""

# SMTP settings for sending emails (optional in development)
# If not set, password reset links will be logged to console
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
