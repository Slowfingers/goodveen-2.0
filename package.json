{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "npm --prefix server run dev",
    "build": "npx prisma generate && npm run server:install && npm run server:prisma && cp -r server api/ && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "server:install": "npm --prefix server install",
    "server:prisma": "npm --prefix server run prisma:generate",
    "server:migrate": "npm --prefix server run prisma:migrate",
    "server:seed": "npm --prefix server run seed",
    "server:studio": "npm --prefix server run prisma:studio"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vendia/serverless-express": "^4.12.6",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.8.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^54.4.1",
    "vite": "^6.2.0"
  }
}
